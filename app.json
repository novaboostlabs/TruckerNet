{
  "expo": {
    "name": "TruckerNet: Driver Finance",
    "slug": "TruckerNet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "truckernet",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novaboostlabs.truckernet",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.novaboostlabs.truckernet",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-camera",
      "expo-image-picker",
      "expo-speech-recognition",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#E8A020",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8a2525c8-a2ae-4b6f-a0f9-1c9e21f76627"
      }
    },
    "owner": "novaboostlabs"
  }
}
