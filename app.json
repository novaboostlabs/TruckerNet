{
  "expo": {
    "name": "TruckerNet: Driver Finance",
    "slug": "TruckerNet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "truckernet",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novaboostlabs.truckernet",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.novaboostlabs.truckernet"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-camera",
      "expo-image-picker",
      "expo-speech-recognition",
      "expo-secure-store",
      "expo-font",
      "expo-asset",
      "expo-web-browser"
    ]
  }
}
