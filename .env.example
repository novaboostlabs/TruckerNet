# Copy this file to ".env" and fill in your real values.
# Anything prefixed with EXPO_PUBLIC_ is readable in the app via process.env.
# After editing .env, restart Expo with a cleared cache:  npx expo start -c

# Supabase (auth + database)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox — powers address autocomplete + auto-mileage on the Check Load screen.
# Use a PUBLIC token (starts with "pk."). Create one free at:
#   https://account.mapbox.com/access-tokens/
# Tip: you can URL-restrict the token to your app for safety.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-public-token
